datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       Int      @id @default(autoincrement())
  name     String
  email    String   @unique
  password String
  role     Role     @default(ADMIN)
}

enum Role {
  ADMIN
  LEITURISTA
}

model Proprietario {
  id        Int       @id @default(autoincrement())
  nome      String
  telefone  String?
  email     String?   @unique
  unidades  Unidade[] // Relação: Um proprietário pode ter várias unidades
  criadoEm  DateTime  @default(now())
}

// Atualize o modelo Unidade (remova o campo String proprietario)
model Unidade {
  id             Int           @id @default(autoincrement())
  numero         String
  bloco          String?
  
  // Nova relação com Proprietario
  proprietarioId Int?
  proprietario   Proprietario? @relation(fields: [proprietarioId], references: [id])
  
  leituras       Leitura[]
  criadoEm       DateTime      @default(now())
}

model Leitura {
  id               Int      @id @default(autoincrement())
  unidadeId        Int
  unidade          Unidade  @relation(fields: [unidadeId], references: [id])
  mesReferencia    Int
  anoReferencia    Int
  leituraAnterior  Float
  leituraAtual     Float
  consumo          Float
  valorTotal       Float
  statusPagamento  Status   @default(PENDENTE)
  dataVencimento   DateTime
  criadoEm         DateTime @default(now())
}

enum Status {
  PAGO
  PENDENTE
  ATRASADO
  FATURADO
}

model Configuracao {
  id               Int   @id @default(1)
  valorMetroCubico Float @default(0.0)
}
